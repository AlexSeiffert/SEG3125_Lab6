<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <title>YouTube UI Survey (Step 1)</title>
    <link rel="stylesheet" href="/styles/styles.css" />
  </head>
  <body>
    <main>
      <header>
        <img class="logo" src="/assets/YoutubeLogo.png" alt="YouTube logo" width="200" />
        <h1>YouTube User Interface Survey</h1>
      </header>

      <p class="site-text-link">
        <a href="https://www.youtube.com" target="_blank" rel="noopener noreferrer">Visit YouTube</a>
      </p>

      <a class="site-link" href="https://www.youtube.com" target="_blank" rel="noopener noreferrer">
        <img src="/assets/YoutubeImage.png" alt="Screenshot of YouTube (Loading failed. Please refresh.)" width="700" />
      </a>

      <p><strong>Step 1 of 3</strong> (2 questions)</p>

      <form action="/survey/2" method="POST">
        <div class="question">
          <label for="q1">What do you like about this website?</label>
          <input type="text" id="q1" name="q1" value="<%= answers.q1 %>"
            placeholder="e.g., recommendations, layout, search..." />
        </div>

        <div class="question">
          <label for="q2">What do you dislike about this website?</label>
          <input type="text" id="q2" name="q2" value="<%= answers.q2 %>"
            placeholder="e.g., ads, clutter, autoplay..." />
        </div>

        <div id="submitbtn">
          <input type="submit" value="Next" />
        </div>
      </form>

      <footer>
        <p>Website designed by Alexander Seiffert, Alexander Yeh, and Macintosh Chen</p>
      </footer>
    </main>
  </body>
</html>