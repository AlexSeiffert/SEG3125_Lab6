<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <title>YouTube UI Survey (Step 2)</title>
    <link rel="stylesheet" href="/styles/styles.css" />
  </head>
  <body>
    <main>
      <header>
        <img class="logo" src="/assets/YoutubeLogo.png" alt="YouTube logo" width="200" />
        <h1>YouTube User Interface Survey</h1>
      </header>

      <p><strong>Step 2 of 3</strong> (2 questions)</p>

      <form action="/survey/3" method="POST">
        <input type="hidden" name="q1" value="<%= answers.q1 %>" />
        <input type="hidden" name="q2" value="<%= answers.q2 %>" />

        <div class="question">
          <fieldset>
            <legend class="question-title">Do you prefer the sidebar on the left or the right?</legend>
            <div class="options">
              <label class="option">
                <input type="radio" name="q3" value="left" required />
                Left
              </label>
              <label class="option">
                <input type="radio" name="q3" value="right" />
                Right
              </label>
              <label class="option">
                <input type="radio" name="q3" value="no-preference" />
                No preference
              </label>
            </div>
          </fieldset>
        </div>

        <div class="question">
          <label for="q4">Is the density of links too high, too low, or about right?</label>
          <select name="q4" id="q4" required>
            <option value="" selected disabled>Select one...</option>
            <option value="too-high">Too high</option>
            <option value="too-low">Too low</option>
            <option value="about-right">About right</option>
          </select>
        </div>

        <div id="submitbtn">
          <input type="submit" value="Next" />
        </div>
      </form>
    </main>
  </body>
</html>